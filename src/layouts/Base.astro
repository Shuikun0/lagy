---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { HOME_LOGO_INTRINSIC, SITE_NAME, SITE_TAB_TITLE } from '../site';
import { getHomeHref, getPublicHref } from '../paths';

interface Props {
  title: string;
  description?: string;
  headerVariant?: 'home' | 'article';
  articleTitle?: string;
  /** 根路径欢迎页：仅保留主题切换与正文区，无站点顶栏 */
  splash?: boolean;
}

const siteName = SITE_NAME;

const { title, description, headerVariant = 'home', articleTitle, splash = false } = Astro.props;
const pageTitle = title === siteName ? SITE_TAB_TITLE : `${title} · ${SITE_TAB_TITLE}`;
const baseUrl = import.meta.env.BASE_URL;
const scriptBase = (baseUrl || '/').replace(/\/?$/, '/');
const homeHref = getHomeHref(baseUrl);
const homeLogoSrc = getPublicHref(baseUrl, 'images/homelogo.png');
const iconSunSrc = getPublicHref(baseUrl, 'images/icon_sun.png');
const iconMoonSrc = getPublicHref(baseUrl, 'images/icon_moon.png');
const postEditorHref = getPublicHref(baseUrl, 'tools/post-editor.html');
const faviconBase = (baseUrl || '/').replace(/\/?$/, '/');
/** public/favicon.png：在 macOS 上用 Apple Color Emoji 离线渲染的 📟（脚本 scripts/render-ios-favicon.swift） */
const faviconHref = `${faviconBase}favicon.png`;
const isHome = headerVariant === 'home';
const isSplash = splash === true;
---

<!doctype html>
<html lang="zh-CN" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <title>{pageTitle}</title>
    <link rel="icon" href={faviconHref} sizes="192x192" type="image/png" />
    <script is:inline>
      (function () {
        /** ClientRouter：下一页 SSR 根节点带默认深色，swap 前从 localStorage 写入，避免浅色被覆盖 */
        window.__blogApplyStoredTheme = function (doc) {
          var d = doc || document;
          try {
            var _t = localStorage.getItem('theme');
            if (_t !== 'light' && _t !== 'dark') _t = 'dark';
            d.documentElement.dataset.theme = _t;
          } catch (e) {
            d.documentElement.dataset.theme = 'dark';
          }
        };
        window.__blogApplyStoredTheme(document);
        document.addEventListener('astro:before-swap', function (ev) {
          window.__blogApplyStoredTheme(ev.newDocument);
        });
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Noto+Serif+SC:wght@500;600&family=Orbitron:wght@500;600;700&family=Rajdhani:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body class:list={[{ 'page-home': isHome && !isSplash, 'page-article': !isHome && !isSplash, 'page-welcome': isSplash }]}>
    <div class:list={['wrap', { 'wrap--splash': isSplash }]}>
      {
        isSplash ? (
          <div class="splash-toolbar">
            <button type="button" class="toolbar-btn theme-toggle" aria-label="切换浅色或深色模式">
              <img
                class="theme-toggle-icon theme-toggle-icon--sun toolbar-icon--match-fg"
                src={iconSunSrc}
                alt=""
                width="29"
                height="29"
                decoding="async"
                draggable={false}
              />
              <img
                class="theme-toggle-icon theme-toggle-icon--moon toolbar-icon--match-fg"
                src={iconMoonSrc}
                alt=""
                width="29"
                height="29"
                decoding="async"
                draggable={false}
              />
            </button>
          </div>
        ) : null
      }
      {
        isSplash ? null : isHome ? (
          <header class="site-header">
            <div class="site-header-primary">
              <h1 class="home-brand-heading">
                <span class="home-logo-wrap">
                  <img
                    class="home-logo home-logo--match-fg"
                    src={homeLogoSrc}
                    alt={siteName}
                    width={HOME_LOGO_INTRINSIC.width}
                    height={HOME_LOGO_INTRINSIC.height}
                    style={`aspect-ratio: ${HOME_LOGO_INTRINSIC.width} / ${HOME_LOGO_INTRINSIC.height}`}
                    decoding="async"
                    draggable={false}
                  />
                </span>
              </h1>
            </div>
            <div class="site-header-toolbar">
              <button type="button" class="toolbar-btn theme-toggle" aria-label="切换浅色或深色模式">
                <img
                  class="theme-toggle-icon theme-toggle-icon--sun toolbar-icon--match-fg"
                  src={iconSunSrc}
                  alt=""
                  width="29"
                  height="29"
                  decoding="async"
                  draggable={false}
                />
                <img
                  class="theme-toggle-icon theme-toggle-icon--moon toolbar-icon--match-fg"
                  src={iconMoonSrc}
                  alt=""
                  width="29"
                  height="29"
                  decoding="async"
                  draggable={false}
                />
              </button>
            </div>
          </header>
        ) : (
          <header class="site-header">
            <div class="site-header-primary">
              <a class="article-home-crumb" href={homeHref}>返回主页</a>
            </div>
            <div class="site-header-toolbar">
              <button type="button" class="toolbar-btn theme-toggle" aria-label="切换浅色或深色模式">
                <img
                  class="theme-toggle-icon theme-toggle-icon--sun toolbar-icon--match-fg"
                  src={iconSunSrc}
                  alt=""
                  width="29"
                  height="29"
                  decoding="async"
                  draggable={false}
                />
                <img
                  class="theme-toggle-icon theme-toggle-icon--moon toolbar-icon--match-fg"
                  src={iconMoonSrc}
                  alt=""
                  width="29"
                  height="29"
                  decoding="async"
                  draggable={false}
                />
              </button>
            </div>
          </header>
        )
      }
      <div class="page-main">
        {
          !isHome && articleTitle ? (
            <div class="article-title-wrap">
              <h1 class="article-header-title">{articleTitle}</h1>
            </div>
          ) : null
        }
        <slot />
      </div>
    </div>
    <!-- 加密文章解锁依赖：须全局加载，以便 ClientRouter 软导航后仍能解密；逻辑在 enc-gate.js 内绑定 astro:page-load -->
    <script is:inline src={`${scriptBase}js/article-crypto.js`}></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/marked@12.0.2/marked.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/dompurify@3.1.7/dist/purify.min.js"></script>
    <script is:inline src={`${scriptBase}js/enc-gate.js`}></script>
    <!-- 晚于 head 中外链 CSS：在 prefers-reduced-motion 下仍播放本站动画，并盖过 Astro viewtransitions.css 的 animation:none（过渡样式见 global.css blog-vt-*）；主页赛博背景动画同理 -->
    <style is:inline>
      @media (prefers-reduced-motion), (prefers-reduced-motion: reduce) {
        .page-main {
          animation: page-main-reveal 0.28s ease-out forwards !important;
        }
        body.page-home .page-main,
        body.page-welcome .page-main {
          animation-delay: 0.04s !important;
        }
        .enc-gate-shake-root.enc-gate-shake {
          animation: enc-gate-shake 0.58s cubic-bezier(0.34, 1.56, 0.64, 1) both !important;
        }
        html:has(body.page-home)::before {
          animation: cp-home-scan-drift 14s linear infinite !important;
        }
        html:has(body.page-home)::after {
          animation: cp-home-grid-shift 22s linear infinite !important;
        }
        html:has(body.page-home) .post-card {
          animation: cp-home-edge-pulse 5.5s ease-in-out infinite !important;
        }
        html[data-astro-transition-fallback='old'] [data-astro-transition-scope],
        html[data-astro-transition-fallback='old'][data-astro-transition-scope] {
          animation: blog-vt-fade-out 200ms ease-out both !important;
        }
        html[data-astro-transition-fallback='new'] [data-astro-transition-scope],
        html[data-astro-transition-fallback='new'][data-astro-transition-scope] {
          animation: blog-vt-fade-in 200ms ease-out both !important;
        }
        html[data-astro-transition='back'][data-astro-transition-fallback='old'] [data-astro-transition-scope],
        html[data-astro-transition='back'][data-astro-transition-fallback='old'][data-astro-transition-scope] {
          animation: blog-vt-fade-out 200ms ease-out both !important;
        }
        html[data-astro-transition='back'][data-astro-transition-fallback='new'] [data-astro-transition-scope],
        html[data-astro-transition='back'][data-astro-transition-fallback='new'][data-astro-transition-scope] {
          animation: blog-vt-fade-in 200ms ease-out both !important;
        }
      }
    </style>
    <script
      is:inline
      set:html={`window.__BLOG_POST_EDITOR_HREF=${JSON.stringify(postEditorHref)};`}
    ></script>
    <script is:inline>
      /** 键盘聚焦标题链接时用手绘下划线（与 :hover 区分） */
      document.addEventListener(
        'focusin',
        function (e) {
          var t = e.target;
          if (!t || !t.closest) return;
          var a = t.closest('a.post-card-link');
          if (a) a.classList.add('post-card-link--kbd-focus');
        },
        true,
      );
      document.addEventListener(
        'focusout',
        function (e) {
          var t = e.target;
          if (!t || !t.closest) return;
          var a = t.closest('a.post-card-link');
          if (a && (!e.relatedTarget || !a.contains(e.relatedTarget))) a.classList.remove('post-card-link--kbd-focus');
        },
        true,
      );

      document.addEventListener(
        'focusin',
        function (e) {
          var t = e.target;
          if (!t || !t.closest) return;
          var a = t.closest('a.article-adjacent-link');
          if (a) a.classList.add('article-adjacent-link--kbd-focus');
        },
        true,
      );
      document.addEventListener(
        'focusout',
        function (e) {
          var t = e.target;
          if (!t || !t.closest) return;
          var a = t.closest('a.article-adjacent-link');
          if (a && (!e.relatedTarget || !a.contains(e.relatedTarget))) a.classList.remove('article-adjacent-link--kbd-focus');
        },
        true,
      );

      document.addEventListener('astro:after-swap', function () {
        if (window.__blogApplyStoredTheme) window.__blogApplyStoredTheme(document);
      });
      document.addEventListener('astro:page-load', function () {
        if (window.__blogApplyStoredTheme) window.__blogApplyStoredTheme(document);
      });

      document.addEventListener('click', function (e) {
        var btn = e.target && e.target.closest && e.target.closest('.theme-toggle');
        if (!btn) return;
        var root = document.documentElement;
        var next = root.dataset.theme === 'dark' ? 'light' : 'dark';
        root.dataset.theme = next;
        try {
          localStorage.setItem('theme', next);
        } catch (err) {}
      });
      document.addEventListener(
        'keydown',
        function (e) {
          if (!document.body.classList.contains('page-home')) return;
          if (e.defaultPrevented) return;
          if (e.metaKey || e.ctrlKey || e.altKey) return;
          if (e.key !== 'i' && e.key !== 'I') return;
          var el = e.target;
          if (el && el.closest && el.closest('input, textarea, select, [contenteditable="true"]')) return;
          e.preventDefault();
          document.body.classList.toggle('show-post-dates');
        },
        true,
      );
      (function () {
        var href = window.__BLOG_POST_EDITOR_HREF;
        if (typeof href !== 'string' || !href) return;
        if (window.__blogPostEditorHotkeyBound) return;
        window.__blogPostEditorHotkeyBound = true;
        document.addEventListener(
          'keydown',
          function (e) {
            if (e.defaultPrevented) return;
            if (e.isComposing) return;
            if (!e.altKey || e.metaKey || e.ctrlKey) return;
            /** macOS Option+字母常把 e.key 变成 π 等，以 code 为准并兼容旧判断 */
            if (e.code !== 'KeyP' && e.key !== 'p' && e.key !== 'P' && e.key !== 'π') return;
            var el = e.target;
            if (el && el.closest && el.closest('input, textarea, select, [contenteditable="true"]')) return;
            e.preventDefault();
            window.location.assign(href);
          },
          true,
        );
      })();
    </script>
  </body>
</html>
