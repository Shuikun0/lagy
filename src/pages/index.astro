---
import Base from '../layouts/Base.astro';
import { SITE_NAME } from '../site';
import { getHomeHref } from '../paths';

const enterHref = getHomeHref(import.meta.env.BASE_URL);
---

<Base title={SITE_NAME} splash>
  <div class="welcome-shell">
    <h1 class="welcome-title">{SITE_NAME}</h1>
    <p class="welcome-lede">欢迎来访。</p>
    <a class="welcome-enter" href={enterHref}>进入博客</a>
  </div>
</Base>
