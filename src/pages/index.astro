---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { SITE_NAME } from '../site';
import { getPostHref, getPublicHref } from '../paths';
import { compareHomePosts } from '../lib/blog-list-order';

const baseUrl = import.meta.env.BASE_URL;
const iconLockSrc = getPublicHref(baseUrl, 'images/icon_lock.png');
const iconPinSrc = getPublicHref(baseUrl, 'images/icon_pin.png');

const allHomePosts = await getCollection('blog', ({ data }) => (import.meta.env.PROD ? data.draft !== true : true));

function isListEncrypted(post: (typeof allHomePosts)[number]) {
  return (
    post.data.encrypted === true &&
    typeof post.data.cipherText === 'string' &&
    typeof post.data.cipherIv === 'string' &&
    typeof post.data.cipherSalt === 'string'
  );
}

const posts = [...allHomePosts].sort(compareHomePosts);

function formatListDate(d: Date) {
  return d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}

function listPostTouchDate(p: (typeof allHomePosts)[number]) {
  return p.data.updatedDate ?? p.data.pubDate;
}

---

<Base title={SITE_NAME} headerVariant="home">
  {
    posts.length === 0 ? (
      <p class="post-card-line home-stream-empty">还没有文章。在 <code>src/content/blog/</code> 下添加 Markdown 后即可在此列出。</p>
    ) : (
      <ul class="post-list home-stream">
        {posts.map((post) => {
          const touchDate = listPostTouchDate(post);
          return (
          <li>
            <div class="post-card">
              <div class="post-card-inner">
                <div class="post-card-heading-block">
                  <h2 class="post-card-title">
                    <a class="post-card-link" href={getPostHref(baseUrl, post.id)}>
                      <span class="post-card-title-text">{post.data.title}</span>
                    </a>
                    {isListEncrypted(post) ? (
                      <span class="post-card-title-badge" aria-label="加密">
                        <img
                          class="post-card-title-icon toolbar-icon--match-fg"
                          src={iconLockSrc}
                          alt=""
                          width="22"
                          height="22"
                          decoding="async"
                          draggable={false}
                        />
                      </span>
                    ) : null}
                    {typeof post.data.pinned === 'number' ? (
                      <span class="post-card-title-badge" aria-label="置顶">
                        <img
                          class="post-card-title-icon toolbar-icon--match-fg"
                          src={iconPinSrc}
                          alt=""
                          width="22"
                          height="22"
                          decoding="async"
                          draggable={false}
                        />
                      </span>
                    ) : null}
                    {import.meta.env.DEV && post.data.draft ? <span class="post-card-draft">草稿</span> : null}
                  </h2>
                  <p class="post-card-meta post-card-date">
                    <time datetime={touchDate.toISOString()}>{formatListDate(touchDate)}</time>
                  </p>
                </div>
                {post.data.listLine ? <p class="post-card-line">{post.data.listLine}</p> : null}
              </div>
            </div>
          </li>
          );
        })}
      </ul>
    )
  }
</Base>
