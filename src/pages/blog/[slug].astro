---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { SITE_TAB_TITLE } from '../../site';
import { getPostHref, getHomeHref } from '../../paths';
import { compareHomePosts } from '../../lib/blog-list-order';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => (import.meta.env.PROD ? data.draft !== true : true));
  const sorted = [...posts].sort(compareHomePosts);
  return sorted.map((post, index) => {
    const prevEntry = index > 0 ? sorted[index - 1] : null;
    const nextEntry = index < sorted.length - 1 ? sorted[index + 1] : null;
    return {
      params: { slug: post.id },
      props: {
        post,
        prevAdjacent: prevEntry ? { id: prevEntry.id, title: prevEntry.data.title } : null,
        nextAdjacent: nextEntry ? { id: nextEntry.id, title: nextEntry.data.title } : null,
      },
    };
  });
}

const baseUrl = import.meta.env.BASE_URL;
const homeHref = getHomeHref(baseUrl);
const { post, prevAdjacent, nextAdjacent } = Astro.props;
const currentPostHref = getPostHref(baseUrl, post.id);
const { Content } = await render(post);

const enc =
  post.data.encrypted === true &&
  typeof post.data.cipherText === 'string' &&
  typeof post.data.cipherIv === 'string' &&
  typeof post.data.cipherSalt === 'string';

/** 与 public/js/article-crypto.js 中 PBKDF2_ITERATIONS 保持一致 */
const defaultCipherIterations = 600000;

const encPayloadJson = enc
  ? JSON.stringify({
      cipherText: post.data.cipherText,
      cipherIv: post.data.cipherIv,
      cipherSalt: post.data.cipherSalt,
      cipherIterations: post.data.cipherIterations ?? defaultCipherIterations,
    })
  : '';

const encMetaJson = enc
  ? JSON.stringify({
      decryptedTitle: (post.data.decryptedTitle ?? '').trim(),
      tabSuffix: SITE_TAB_TITLE,
    }).replace(/</g, '\\u003c')
  : '';

const hint = enc ? (post.data.passwordHint ?? '').trim() : '';
---

<Base title={post.data.title} description={post.data.description} headerVariant="article" articleTitle={post.data.title}>
  <article class="article-shell prose">
    {
      enc ? (
        <>
          <div class="enc-gate" id="enc-gate">
            {hint ? (
              <div class="enc-gate-hint prose" id="enc-hint-rendered" data-hint-encoded={encodeURIComponent(hint)} />
            ) : null}
            <form class="enc-gate-form" id="enc-form" autocomplete="off">
              <div id="enc-gate-shake-root" class="enc-gate-shake-root">
                <div id="enc-pass-wrap" class="enc-gate-input-wrap">
                  <input
                    type="text"
                    id="enc-pass"
                    name="password"
                    class="enc-gate-input"
                    autocomplete="off"
                    spellcheck="false"
                    inputmode="text"
                    aria-label="输入暗号；按 Enter 确认解锁"
                  />
                </div>
                <p
                  class="enc-gate-msg"
                  id="enc-msg"
                  role="status"
                  aria-live="polite"
                  data-default-msg="输入暗号解锁文章，回车键确认"
                >
                  输入暗号解锁文章，回车键确认
                </p>
              </div>
            </form>
          </div>
          <div class="enc-body prose" id="enc-body" hidden />
          <script type="application/json" id="enc-meta" set:html={encMetaJson} />
          <script type="application/json" id="enc-payload" set:html={encPayloadJson} />
        </>
      ) : (
        <Content />
      )
    }
  </article>
  <footer class="article-doc-footer" aria-label="文末导航">
    <nav class="article-adjacent" aria-label="相邻文章">
      <div class="article-adjacent-inner">
        <div class="article-adjacent-cell article-adjacent-cell--prev">
          {
            prevAdjacent ? (
              <a class="article-adjacent-link" href={getPostHref(baseUrl, prevAdjacent.id)}>
                <span class="article-adjacent-label">上一篇</span>
                <span class="article-adjacent-title-shell">
                  <span class="article-adjacent-title-text">{prevAdjacent.title}</span>
                </span>
              </a>
            ) : (
              <a class="article-adjacent-link article-adjacent-link--noop" href={currentPostHref}>
                <span class="article-adjacent-label">上一篇</span>
                <span class="article-adjacent-title-shell">
                  <span class="article-adjacent-title-text">没有了</span>
                </span>
              </a>
            )
          }
        </div>
        <div class="article-adjacent-cell article-adjacent-cell--next">
          {
            nextAdjacent ? (
              <a class="article-adjacent-link" href={getPostHref(baseUrl, nextAdjacent.id)}>
                <span class="article-adjacent-label">下一篇</span>
                <span class="article-adjacent-title-shell">
                  <span class="article-adjacent-title-text">{nextAdjacent.title}</span>
                </span>
              </a>
            ) : (
              <a class="article-adjacent-link article-adjacent-link--noop" href={currentPostHref}>
                <span class="article-adjacent-label">下一篇</span>
                <span class="article-adjacent-title-shell">
                  <span class="article-adjacent-title-text">没有了</span>
                </span>
              </a>
            )
          }
        </div>
      </div>
    </nav>
    <p class="article-foot-nav-home">
      <a class="article-home-crumb" href={homeHref}>返回主页</a>
    </p>
  </footer>
</Base>
